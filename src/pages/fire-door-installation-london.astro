---
import Layout from "../layouts/Layout.astro";
import PageShell from "../components/PageShell";
import FireDoorInstallationPage from "../site/pages/FireDoorInstallation";

const fireDoorJsonLd = [
  {
    "@context": "https://schema.org",
    "@type": "Service",
    name: "Fire Door Installation London",
    provider: {
      "@type": "HomeAndConstructionBusiness",
      name: "Focus Refurbishment Ltd",
      url: "https://focusrefurbishmentltd.com",
      telephone: "02046340020",
      address: {
        "@type": "PostalAddress",
        streetAddress: "144 Hurst Road",
        addressLocality: "Sidcup",
        addressRegion: "Kent",
        postalCode: "DA15 9AF",
        addressCountry: "GB",
      },
    },
    areaServed: ["London", "South East London", "South West London", "Central London", "Kent"],
    description:
      "Approved FD30 and FD60 fire door installation across London and the M25. Fully certified with compliance documentation supplied. Trusted by landlords, estate agents and facilities managers.",
    serviceType: "Fire Door Installation",
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    mainEntity: [
      {
        "@type": "Question",
        name: "How quickly can you carry out a survey?",
        acceptedAnswer: {
          "@type": "Answer",
          text: "We aim to carry out surveys within the week of your enquiry.",
        },
      },
      {
        "@type": "Question",
        name: "What documentation do I receive after installation?",
        acceptedAnswer: {
          "@type": "Answer",
          text: "You receive full compliance documentation including installer certificates and product data sheets.",
        },
      },
      {
        "@type": "Question",
        name: "Do you work on HMOs and multi-property portfolios?",
        acceptedAnswer: {
          "@type": "Answer",
          text: "Yes — we regularly work with landlords and estate agents managing multiple HMOs and can schedule across multiple properties efficiently.",
        },
      },
      {
        "@type": "Question",
        name: "What areas do you cover?",
        acceptedAnswer: {
          "@type": "Answer",
          text: "We cover London and the South East, including all areas within the M25.",
        },
      },
      {
        "@type": "Question",
        name: "Is there a minimum job size?",
        acceptedAnswer: {
          "@type": "Answer",
          text: "Our minimum call-out is £300.",
        },
      },
    ],
  },
];
---

<Layout
  title="Fire Door Installation London | Approved Installers | Focus Refurbishment"
  description="Approved fire door installers covering London and the M25. FD30 & FD60 doors supplied, fitted and certified. Trusted by landlords and estate agents. Free quote."
  canonicalUrl="https://focusrefurbishmentltd.com/fire-door-installation-london"
  ogTitle="Fire Door Installation London | Approved Installers | Focus Refurbishment"
  ogDescription="Approved fire door installers covering London and the M25. FD30 & FD60 doors supplied, fitted and certified. Trusted by landlords and estate agents. Free quote."
  ogUrl="https://focusrefurbishmentltd.com/fire-door-installation-london"
  extraJsonLd={fireDoorJsonLd}
>
  <PageShell client:idle>
    <FireDoorInstallationPage />
  </PageShell>
</Layout>
