---
import "../styles/global.css";

export interface Props {
  title: string;
  description: string;
  canonicalUrl: string;
  ogTitle?: string;
  ogDescription?: string;
  ogUrl?: string;
  ogImage?: string;
  /** Defaults to ogDescription; homepage may use a shorter Twitter card blurb */
  twitterDescription?: string;
  robots?: string;
  /** HomeAndConstructionBusiness JSON-LD on homepage only */
  includeLocalBusinessJsonLd?: boolean;
  /** Additional JSON-LD objects to render in <head> — e.g. FAQPage, Service */
  extraJsonLd?: object[];
}

const site = "https://focusrefurbishmentltd.com";
const {
  title,
  description,
  canonicalUrl,
  ogTitle = title,
  ogDescription = description,
  ogUrl = canonicalUrl,
  ogImage = `${site}/images/og-image.jpg`,
  twitterDescription,
  robots,
  includeLocalBusinessJsonLd = false,
  extraJsonLd,
} = Astro.props;

const twitterDesc = twitterDescription ?? ogDescription;

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "HomeAndConstructionBusiness",
  name: "Focus Refurbishment Ltd",
  alternateName: "Focus Group",
  url: site,
  logo: `${site}/images/logo.png`,
  image: `${site}/images/og-image.jpg`,
  description:
    "Premium refurbishment, extensions, loft conversions, fire door installation, and building maintenance across London & South East. Family-run since 2000.",
  telephone: "02046340020",
  email: "office@focusrefurbishmentltd.com",
  address: {
    "@type": "PostalAddress",
    streetAddress: "144 Hurst Road",
    addressLocality: "Sidcup",
    addressRegion: "Kent",
    postalCode: "DA15 9AF",
    addressCountry: "GB",
  },
  geo: {
    "@type": "GeoCoordinates",
    latitude: 51.4279,
    longitude: 0.105,
  },
  areaServed: ["South East London", "South West London", "Central London", "London", "Kent"],
  foundingDate: "2000",
  numberOfEmployees: { "@type": "QuantitativeValue", value: 22 },
  sameAs: [
    "https://www.instagram.com/focus_refurbishment_ltd/",
    "https://www.facebook.com/p/Focus-Refurbishment-LTD-100063782545076/",
  ],
  openingHoursSpecification: [
    {
      "@type": "OpeningHoursSpecification",
      dayOfWeek: ["Monday", "Tuesday", "Wednesday", "Thursday", "Friday", "Saturday"],
      opens: "08:00",
      closes: "17:00",
    },
  ],
  hasOfferCatalog: {
    "@type": "OfferCatalog",
    name: "Building & Refurbishment Services",
    itemListElement: [
      { "@type": "Offer", itemOffered: { "@type": "Service", name: "Fire Door Installation" } },
      { "@type": "Offer", itemOffered: { "@type": "Service", name: "Property Refurbishment" } },
      { "@type": "Offer", itemOffered: { "@type": "Service", name: "Loft Conversions" } },
      { "@type": "Offer", itemOffered: { "@type": "Service", name: "House Extensions" } },
      { "@type": "Offer", itemOffered: { "@type": "Service", name: "Building Maintenance Contracts" } },
      { "@type": "Offer", itemOffered: { "@type": "Service", name: "Rubbish Removal" } },
      { "@type": "Offer", itemOffered: { "@type": "Service", name: "EWI & Render" } },
      { "@type": "Offer", itemOffered: { "@type": "Service", name: "Roofing" } },
      { "@type": "Offer", itemOffered: { "@type": "Service", name: "Loft Conversions" } },
      { "@type": "Offer", itemOffered: { "@type": "Service", name: "Painting & Decorating" } },
      { "@type": "Offer", itemOffered: { "@type": "Service", name: "Summer Houses/Annexes" } },
    ],
  },
};
---

<!doctype html>
<html lang="en-GB">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    {robots && <meta name="robots" content={robots} />}
    <link rel="canonical" href={canonicalUrl} />

    <meta name="geo.region" content="GB-KEN" />
    <meta name="geo.placename" content="Sidcup, London" />
    <meta name="author" content="Focus Refurbishment Ltd" />

    <meta property="og:title" content={ogTitle} />
    <meta property="og:description" content={ogDescription} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={ogUrl} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:locale" content="en_GB" />
    <meta property="og:site_name" content="Focus Refurbishment Ltd" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={ogTitle} />
    <meta name="twitter:description" content={twitterDesc} />
    <meta name="twitter:image" content={ogImage} />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;0,9..40,600;0,9..40,700;1,9..40,400&family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap"
    />

    <link rel="icon" href="/favicon.ico" sizes="any" />
    <link rel="icon" type="image/png" sizes="96x96" href="/favicon-96x96.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />

    <meta name="google-site-verification" content="U9LuqipEGS_gRz_Avcy6Vi_HFLGviDyWGv_OoQc9M8w" />

    <script is:inline async src="https://www.googletagmanager.com/gtag/js?id=G-5Y4789V5YK"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag() {
        dataLayer.push(arguments);
      }
      window.gtag = gtag;

      window.gtag_report_conversion = function (url) {
        var navigated = false;
        var callback = function () {
          if (navigated) return;
          navigated = true;
          if (typeof url !== "undefined") {
            window.location = url;
          }
        };

        gtag("event", "conversion", {
          send_to: "AW-18087305153/rm49CJr556UcEMG_2bBD",
          value: 1.0,
          currency: "GBP",
          event_callback: callback,
        });

        window.setTimeout(callback, 1200);
        return false;
      };

      gtag("js", new Date());
      gtag("config", "G-5Y4789V5YK");
      gtag("config", "AW-18087305153");
    </script>

    {
      includeLocalBusinessJsonLd && (
        <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
      )
    }
    {
      extraJsonLd && extraJsonLd.map((blob, i) => (
        <script type="application/ld+json" set:html={JSON.stringify(blob)} />
      ))
    }
  </head>
  <body>
    <slot />
    <script is:inline>
      document.addEventListener("click", (event) => {
        const target = event.target;
        if (!(target instanceof Element)) return;

        const link = target.closest('a[href^="tel:"]');
        if (!(link instanceof HTMLAnchorElement)) return;

        const href = link.getAttribute("href");
        if (!href || typeof window.gtag_report_conversion !== "function") return;

        event.preventDefault();
        window.gtag_report_conversion(href);
      });

      const loadThirdPartyScript = (src, attrs = {}) => {
        const script = document.createElement("script");
        script.src = src;
        script.defer = true;
        Object.entries(attrs).forEach(([key, value]) => {
          script.setAttribute(key, String(value));
        });
        document.body.appendChild(script);
      };

      const bootThirdPartyScripts = () => {
        loadThirdPartyScript("https://beta.leadconnectorhq.com/loader.js", {
          "data-resources-url": "https://beta.leadconnectorhq.com/chat-widget/loader.js",
          "data-widget-id": "699f1d835fe82b2a9d31b403",
        });
        loadThirdPartyScript("https://link.nobleleads.uk/js/form_embed.js");
      };

      if ("requestIdleCallback" in window) {
        window.requestIdleCallback(bootThirdPartyScripts, { timeout: 3000 });
      } else {
        window.addEventListener("load", () => setTimeout(bootThirdPartyScripts, 500), { once: true });
      }
    </script>
  </body>
</html>
